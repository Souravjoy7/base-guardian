# Base Guardian Environment Configuration
# Copy this file to .env and fill in your values

# Deployer wallet private key (without 0x prefix)
PRIVATE_KEY=

# Base RPC endpoints
BASE_RPC_URL=https://goerli.base.org
BASE_WS_URL=wss://goerli.base.org/ws

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Alert webhook (Discord/Slack)
ALERT_WEBHOOK_URL=

# Gas reporting (optional)
REPORT_GAS=false
COINMARKETCAP_API_KEY=

# Monitoring configuration
HEARTBEAT_INTERVAL=12
GAS_SPIKE_THRESHOLD=200
MAX_MISSED_HEARTBEATS=50
